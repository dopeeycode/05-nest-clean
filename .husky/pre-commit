#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ─── 1. Bloquear console.log em todos os arquivos .ts da src/ ────────────────

echo "🔍 [pre-commit] Verificando console.log em src/..."

CONSOLE_LOG_FOUND=$(grep -rn "console\.log" src/ --include="*.ts" 2>/dev/null || true)

if [ -n "$CONSOLE_LOG_FOUND" ]; then
  echo ""
  echo "❌ [pre-commit] console.log encontrado! Remova antes de commitar:"
  echo ""
  echo "$CONSOLE_LOG_FOUND"
  echo ""
  exit 1
fi

echo "✅ Nenhum console.log encontrado."
echo ""

# ─── 2. Type-check ────────────────────────────────────────────────────────────

echo "🔷 [pre-commit] Verificando tipos TypeScript..."

pnpm tsc --noEmit
TSC_STATUS=$?

if [ $TSC_STATUS -ne 0 ]; then
  echo ""
  echo "❌ [pre-commit] Erro de tipos TypeScript. Corrija antes de commitar."
  exit 1
fi

echo "✅ TypeScript OK."
echo ""

# ─── 3. Lint ─────────────────────────────────────────────────────────────────

echo "🔶 [pre-commit] Executando lint..."

pnpm run lint
LINT_STATUS=$?

if [ $LINT_STATUS -ne 0 ]; then
  echo ""
  echo "❌ [pre-commit] Erros de lint encontrados. Corrija antes de commitar."
  exit 1
fi

echo ""
echo "✅ [pre-commit] Tudo certo! Commit liberado. 🚀"
